# English letter frequencies (percentages)
ENGLISH_FREQ = {
    'A': 8.167, 'B': 1.492, 'C': 2.782, 'D': 4.253, 'E': 12.702,
    'F': 2.228, 'G': 2.015, 'H': 6.094, 'I': 6.966, 'J': 0.153,
    'K': 0.772, 'L': 4.025, 'M': 2.406, 'N': 6.749, 'O': 7.507,
    'P': 1.929, 'Q': 0.095, 'R': 5.987, 'S': 6.327, 'T': 9.056,
    'U': 2.758, 'V': 0.978, 'W': 2.360, 'X': 0.150, 'Y': 1.974,
    'Z': 0.074
}

def score_text(text):
    # Chi-squared score comparing letter frequencies to English. Lower is better.
    letters = [c for c in text if c.isalpha()]
    total = len(letters)
    if len(letters) == 0:
        return float('inf')
    
    #coount each letter
    counts = {}
    for c in letters:
        counts[c] = counts.get(c, 0) + 1 #with text="HELLO", counts={'H':1, 'E':1, 'L':2, 'O':1}

    #chi-squared : compare observed % vs expected % for each letter. sum of ((observed - expected)^2 / expected) for all letters
    chi_squared = 0.0
    for letter in "ABCDEFGHIJKLMNOPQRSTUVWXYZ":
        observed = (counts.get(letter, 0) / total) * 100.0 #example: for letter 'L', observed = (2/5)*100 = 40.0
        expected = ENGLISH_FREQ[letter]
        chi_squared += ((observed - expected) ** 2) / expected
    return chi_squared


