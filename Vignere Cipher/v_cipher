def vigenere_decrypt(text, key):
    #Decrypt text using Vigenere cipher with given key.
    if not key:
        return text
    result = [] #after inputting text="hello" , ["H", "E", "L", "L", "O"] with some key
    key = key.upper()
    key_len = len(key)
    key_index = 0
    for c in text:
        if c.isalpha():
            shift = ord(key[key_index % key_len]) - ord('A')
            decrypted = chr((ord(c) - ord('A') - shift) % 26 + ord('A'))
            result.append(decrypted) # adds to the list , by each decrypted character with the key shift applied
            key_index += 1
        else:
            result.append(c)
    return ''.join(result) #seperator is empty so joins all together in a string, or array.
    
