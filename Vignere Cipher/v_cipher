def index_of_coincidence(text):
    #calculate index of coincidence for text. Higher is more likely to be English.
    letters = [c for c in text if c.isalpha()]
    if len(letters) == 0:
        return 0.0 # why
    counts = {}
    for c in letters:
        counts[c] = counts.get(c, 0) +1 #explain? 
    
    #IC formula: sum of n_i(n_i-1) / N(N-1) where n_i is count of each letter and N is total letters
    total = len(letters)
    numerator = 0
    denominator = total * (total - 1)
    for count in counts.values(): #explain?
        numerator += count * (count - 1)
        
    if denominator == 0:
        return 0.0
    return numerator / denominator





